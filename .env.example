# === Default model provider ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
DEFAULT_MODEL_ID=deepseek-chat-legacy

# === Optional low-cost / comparison model keys ===
SILICONFLOW_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
GEMINI_API_KEY=

# === Optional custom model presets ===
# Use apiKeyEnv to reference a secret environment variable.
# MODEL_PRESETS_JSON=[
#   {
#     "id": "cheap-qwen",
#     "label": "Cheap Qwen 7B",
#     "provider": "Custom",
#     "baseUrl": "https://example.com/v1",
#     "apiKeyEnv": "CUSTOM_API_KEY",
#     "model": "qwen2.5-7b-instruct",
#     "riskBias": 0.15,
#     "completionMode": true
#   }
# ]

# === Retrieval ===
WEB_SEARCH_ENABLED=true
SERPER_API_KEY=
BING_SEARCH_API_KEY=
EMBEDDING_MODEL=

# === Public deployment controls ===
# If true, visitors can submit their own temporary API key through the page.
# Keep false for a public demo unless you trust the users.
ALLOW_CUSTOM_MODELS=false

# === Server ===
PORT=5177
CORPUS_DIRS=./corpus
